{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@esparex/core/*": ["core/src/*"],
      "@esparex/shared": ["shared/src"],
      "@esparex/shared/*": ["shared/src/*"],
      "@esparex/contracts": ["packages/contracts/src"],
      "@esparex/contracts/*": ["packages/contracts/src/v1/*"],
      "@esparex/ui": ["packages/ui/src"],
      "@esparex/ui/*": ["packages/ui/src/*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "composite": true,
    "declaration": true,
    "noEmitOnError": true
  },
  "files": [],
  "references": [
    { "path": "./packages/contracts" },
    { "path": "./packages/ui" },
    { "path": "./core" },
    { "path": "./shared" },
    { "path": "./backend/api" },
    { "path": "./apps/web" },
    { "path": "./apps/admin" }
  ]
}
