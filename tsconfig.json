{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@core/*": ["core/src/*"],
      "@shared/*": ["shared/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "composite": true,
    "declaration": true
  },
  "files": [],
