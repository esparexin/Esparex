{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@esparex/core": ["core/src"],
      "@esparex/core/models": ["core/src/models/index"],
      "@esparex/core/services": ["core/src/services/index"],
      "@esparex/core/events": ["core/src/events/index"],
      "@esparex/core/utils": ["core/src/utils/index"],
      "@esparex/core/config": ["core/src/config/index"],
      "@esparex/core/infrastructure": ["core/src/infrastructure/index"],
      "@esparex/core/types": ["core/src/types/index"],
      "@esparex/core/validators": ["core/src/validators/index"],
      "@esparex/core/jobs": ["core/src/jobs/index"],
      "@esparex/core/queues": ["core/src/queues/index"],
      "@esparex/core/workers": ["core/src/workers/index"],
      "@esparex/core/domain": ["core/src/domain/index"],
      "@esparex/core/tooling": ["core/src/tooling/index"],
      "@esparex/core/../package.json": ["core/package.json"],
      "@esparex/shared": ["shared/src"],
      "@esparex/shared/*": ["shared/src/*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "composite": true,
    "declaration": true
  },
  "files": [],
  "references": [
    { "path": "./core" },
    { "path": "./shared" },
    { "path": "./backend/user" },
    { "path": "./apps/web" },
    { "path": "./apps/admin" }
  ]
}
