{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@esparex/core/*": ["core/src/*"],
      "@esparex/shared": ["shared/src"],
      "@esparex/shared/*": ["shared/src/*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "composite": true,
    "declaration": true
  },
  "files": [],
  "references": [
    { "path": "./core" },
    { "path": "./shared" },
    { "path": "./backend/api" },
    { "path": "./apps/web" },
    { "path": "./apps/admin" }
  ]
}
