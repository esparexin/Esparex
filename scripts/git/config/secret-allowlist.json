{
  "_comment": "Files matching these patterns are exempt from secret scanning.",
  "filePatterns": [
    ".env.example",
    ".env.schema",
    ".env.test",
    ".env.local.example",
    ".env.production.example",
    ".env.development.example"
  ],
  "fileGlobs": [
    "**/*.example",
    "**/.env.*.example"
  ],
  "testFilePatterns": [
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.js",
    "**/*.spec.jsx",
    "**/*.test.js",
    "**/*.test.jsx",
    "**/__tests__/**",
    "**/__mocks__/**",
    ".github/workflows/ci.yml",
    "scripts/git/secret-scan.js"
  ],
  "approvedCredentials": {
    "_note": "Keys/secrets that are intentionally committed (e.g., test fixtures).",
    "patterns": []
  }
}
