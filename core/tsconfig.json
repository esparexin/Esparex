{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": ".",
    "rootDir": "./src",
    "outDir": "./dist",
    "composite": false,
    "declaration": true,
    "declarationMap": false,
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@core/*": ["./src/*"],
      "@esparex/core/*": ["./src/*"],
      "@esparex/shared": ["../shared/dist/index"],
      "@esparex/contracts": ["../packages/contracts/dist/index"],
      "@esparex/contracts/*": ["../packages/contracts/dist/*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
