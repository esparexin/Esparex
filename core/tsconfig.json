{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "rootDir": "..",
    "outDir": "./dist",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "lib": ["ES2023", "DOM"],
    "paths": {
      "@shared/*": ["../shared/*"],
      "@shared": ["../shared/index.ts"],
      "@core/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*",
    "../shared/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
