{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "./src",
    "outDir": "./dist",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "@shared/*": ["../shared/dist/*"],
      "@shared": ["../shared/dist/index.d.ts"],
      "@core/*": ["src/*"],
      "@core": ["src/index.ts"]
    }
  },
  "references": [
    { "path": "../shared" }
  ],
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
