{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "rootDir": "..",
    "outDir": "./dist",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@shared/*": ["../shared/*"],
      "@shared": ["../shared/index.ts"],
      "@core/*": ["src/*"],
      "@core": ["src/index.ts"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/__tests__",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
