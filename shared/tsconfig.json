{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "node16",
    "baseUrl": ".",
    "paths": {
      "@esparex/contracts": ["../packages/contracts/src/index"],
      "@esparex/contracts/*": ["../packages/contracts/src/v1/*"]
    },
    "rootDir": "./src",
    "outDir": "./dist",
    "composite": true,
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "references": [
    { "path": "../packages/contracts" }
  ],
  "include": ["src/**/*", "src/**/*.json"],
  "exclude": ["node_modules", "dist"]
}
