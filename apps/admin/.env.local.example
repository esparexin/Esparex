# Esparex Admin - Local Environment Template
# Copy this file to .env.local
# SSOT: core/src/config/env.ts

# 1. RUNTIME & API
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_PROD_RISK_OVERRIDE=false
# Points to the unified backend-api instance running in API role
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:5001/api/v1/admin
NEXT_PUBLIC_ADMIN_API_TIMEOUT_MS=20000
