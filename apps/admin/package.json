{
    "name": "@esparex/apps-admin",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "engines": {
        "node": "^22.0.0"
    },
    "scripts": {
        "clean": "node ../../scripts/kill-port.js 3001 && node ../../scripts/clean.js --admin",
        "predev": "npm run clean",
        "dev": "next dev -p 3001",
        "build": "cross-env NEXT_DISABLE_WEBPACK_CACHE=1 next build --webpack",
        "analyze": "cross-env ANALYZE=true next build --webpack",
        "start": "next start -p 3001",
        "type-check": "tsc --noEmit",
        "guard:admin": "node scripts/admin-guardrails.mjs",
        "guard:ui": "node scripts/admin-ui-guard.mjs",
        "test:settings-regression": "node scripts/settings-regression.mjs",
        "test:moderation-regression": "node scripts/moderation-regression.mjs",
        "ci:guardrails": "npm run type-check && npm run guard:admin && npm run guard:ui && npm run test:moderation-regression && npm run test:settings-regression",
        "e2e": "node scripts/run-playwright.mjs",
        "e2e:list": "playwright test --list",
        "lint": "eslint .",
        "guard:unused-imports": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0 --rule \"unused-imports/no-unused-imports:error\""
    },
    "dependencies": {
        "@esparex/contracts": "*",
        "@esparex/shared": "*",
        "@esparex/ui": "*",
        "@hookform/resolvers": "^5.4.0",
        "@radix-ui/react-dialog": "^1.1.21",
        "@tanstack/react-virtual": "^3.14.8",
        "date-fns": "^4.4.0",
        "lucide-react": "^1.26.0",
        "next": "^16.2.11",
        "react": "^19.2.8",
        "react-dom": "^19.2.8",
        "react-hook-form": "^7.82.0",
        "react-is": "^19.2.8",
        "recharts": "^3.10.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@next/bundle-analyzer": "^16.2.11",
        "@playwright/test": "^1.61.1",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "autoprefixer": "^10.5.4",
        "cross-env": "^10.1.0",
        "postcss": "^8.5.22",
        "tailwindcss": "^4.3.3",
        "typescript": "^7.0.2"
    }
}
