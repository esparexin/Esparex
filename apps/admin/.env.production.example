# Esparex Admin - Production Environment Template
# 🚨 SECURITY: All NEXT_PUBLIC_ variables are exposed to the browser.
# DO NOT put server-side secrets here.

# 1. RUNTIME & API
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_PROD_RISK_OVERRIDE=false
NEXT_PUBLIC_ADMIN_API_URL=https://api.esparex.in/api/v1/admin
NEXT_PUBLIC_ADMIN_API_TIMEOUT_MS=30000

# 2. ANALYTICS (Optional)
# NEXT_PUBLIC_GA_ID=
