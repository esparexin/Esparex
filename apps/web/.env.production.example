# Esparex Web - Production Environment Template
# 🚨 SECURITY: All NEXT_PUBLIC_ variables are exposed to the browser.
# DO NOT put server-side secrets here.

# 1. RUNTIME & API
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_PROD_RISK_OVERRIDE=false
NEXT_PUBLIC_API_URL=https://api.esparex.in/api/v1
NEXT_PUBLIC_APP_URL=https://esparex.in

# Internal URL for Next.js SSR (Server-to-Server)
# Use this if backend and frontend are in the same private network (e.g. Render/AWS)
# BACKEND_INTERNAL_URL=http://backend-api:10000

# 2. FIREBASE (Production)
NEXT_PUBLIC_FIREBASE_API_KEY=your-production-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-production-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-production-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-production-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-web-push-vapid-key
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
