{
  "name": "@esparex/apps-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--disable-warning=DEP0169 next dev -p 3000",
    "build": "cross-env SKIP_ENV_VALIDATION=true NEXT_DISABLE_WEBPACK_CACHE=1 next build --webpack",
    "analyze:routes": "node scripts/analyze-next-build.cjs",
    "analyze:build": "npm run build && npm run analyze:routes",
    "start": "cross-env NODE_OPTIONS=--disable-warning=DEP0169 next start -p 3000",
    "lint": "eslint .",
    "lint:image-domains": "node scripts/validate-image-domains.cjs",
    "ci:image-domains": "node scripts/validate-image-domains.cjs",
    "type-check": "tsc --noEmit",
    "seed:locations:full": "echo \"Moved to backend ops; run from backend package.\" && exit 1",
    "api:generate": "openapi-zod-client http://localhost:5001/api-docs.json -o src/api/generated",
    "test": "vitest",
    "e2e": "playwright test",
    "e2e:listing-edit": "playwright test tests/edit-listing.spec.ts --project=chromium --workers=4",
    "e2e:listing-edit:ci": "playwright test tests/edit-listing.spec.ts --project=chromium --workers=1",
    "test:smoke": "playwright test tests/listing-chat-smoke.spec.ts",
    "guard:unused-imports": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0 --rule \"unused-imports/no-unused-imports:error\""
  },
  "dependencies": {
    "@esparex/shared": "*",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-aspect-ratio": "^1.1.11",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.3.3",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-hover-card": "^1.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-menubar": "^1.1.20",
    "@radix-ui/react-navigation-menu": "^1.2.18",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@react-google-maps/api": "^2.20.7",
    "@sentry/nextjs": "^10.66.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.6",
    "@zodios/core": "^10.9.6",
    "axios": "^1.18.1",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "crypto-js": "^4.2.0",
    "embla-carousel-react": "^8.6.0",
    "file-type": "^22.0.1",
    "firebase": "^12.16.0",
    "framer-motion": "^12.42.2",
    "fuse.js": "^7.5.0",
    "heic2any": "^0.0.4",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.4",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-resizable-panels": "^4.12.2",
    "recharts": "^3.9.2",
    "sharp": "^0.35.3",
    "socket.io-client": "^4.8.3",
    "socket.io-parser": "^4.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@types/crypto-js": "^4.2.2",
    "@types/google.maps": "^3.65.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.4",
    "dotenv": "^17.2.3",
    "eslint": "^10.7.0",
    "eslint-config-next": "^16.2.10",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "openapi-zod-client": "^1.18.3",
    "postcss": "^8.5.19",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "browserslist": [
    ">0.3%",
    "not dead",
    "not op_mini all"
  ]
}
