{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean": "lsof -ti:5001 | xargs kill -9 || true",
    "predev": "npm run clean",
    "start": "NODE_ENV=production node -r ts-node/register/transpile-only -r tsconfig-paths/register dist/backend/src/index.js",
    "start:dev": "node dist/backend/src/index.js",
    "start:ts": "ts-node --files -r tsconfig-paths/register src/index.ts",
    "dev": "nodemon",
    "build": "rm -rf dist && tsc",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint src --ext .ts --fix",
    "db:seed": "ts-node -r tsconfig-paths/register src/seeds/runSeeds.ts",
    "seed:admin": "ts-node -r tsconfig-paths/register src/scripts/seed-admin.ts",
    "backup": "ts-node src/scripts/backup-database.ts",
    "restore": "ts-node src/scripts/restore-database.ts",
    "verify-backup": "ts-node src/scripts/verify-backup.ts",
    "test": "NODE_NO_WARNINGS=1 jest",
    "test:unit": "NODE_NO_WARNINGS=1 jest --testPathIgnorePatterns=src/__tests__/integration",
    "test:integration": "NODE_NO_WARNINGS=1 jest --testPathPatterns=integration",
    "test:integration:db": "NODE_NO_WARNINGS=1 ALLOW_DB_CONNECT=true jest --testPathPatterns=integration --runInBand --passWithNoTests --forceExit",
    "test:integration:db:strict": "NODE_NO_WARNINGS=1 ALLOW_DB_CONNECT=true jest --testPathPatterns=integration --runInBand --passWithNoTests --forceExit --json --outputFile=jest-integration-results.json && node scripts/assert-no-skipped-integration-tests.js jest-integration-results.json && rm -f jest-integration-results.json",
    "test:watch": "NODE_NO_WARNINGS=1 jest --watch",
    "test:coverage": "NODE_NO_WARNINGS=1 jest --coverage",
    "test:ci": "NODE_NO_WARNINGS=1 jest --coverage --passWithNoTests --ci",
    "ops": "ts-node -r tsconfig-paths/register src/scripts/ops/index.ts",
    "ops:geo-repair": "npm run ops -- geo-repair",
    "ops:report-unify": "npm run ops -- report-unify-backfill",
    "ops:report-orphans": "npm run ops -- report-orphan-remediate",
    "migrate:ad-listingtype-backfill": "ts-node -r tsconfig-paths/register src/scripts/migrate_ad_listingtype_backfill.ts",
    "migrate:lifecycle-integrity-sweep": "ts-node -r tsconfig-paths/register src/scripts/migrations/migrate_listing_lifecycle_integrity.ts",
    "scan:master-data-integrity": "node scripts/master-data-integrity-scan.js",
    "ops:indexes:apply": "ts-node scripts/syncUserIndexes.ts && ts-node scripts/sync_ad_indexes.ts",
    "ops:indexes:rename-prefix:dry": "ts-node -r tsconfig-paths/register scripts/rename_index_names_to_idx_prefix.ts",
    "ops:indexes:rename-prefix:apply": "ts-node -r tsconfig-paths/register scripts/rename_index_names_to_idx_prefix.ts --apply",
    "audit:duplicates": "npx jscpd ./src ../frontend/src --ignore \"**/*.d.ts,**/node_modules/**,**/.next/**,**/dist/**\"",
    "migrate:create": "migrate-mongo create",
    "migrate:up": "migrate-mongo up",
    "migrate:down": "migrate-mongo down",
    "migrate:status": "migrate-mongo status",
    "guard:duplicate-rollout": "node scripts/check-duplicate-rollout-readiness.js",
    "s3:probe": "node scripts/s3-probe.js",
    "guard:unused-imports": "eslint \"src/**/*.ts\" --max-warnings=0 --rule \"unused-imports/no-unused-imports:error\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.954.0",
    "@aws-sdk/s3-request-presigner": "^3.975.0",
    "@bull-board/api": "^6.20.3",
    "@bull-board/express": "^6.20.3",
    "@sentry/node": "^10.38.0",
    "@sentry/profiling-node": "^10.38.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@turf/boolean-point-in-polygon": "^7.3.1",
    "@turf/helpers": "^7.3.1",
    "@types/csurf": "^1.11.5",
    "@types/multer": "^2.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "axios": "^1.13.3",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.70.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csurf": "^1.11.0",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^13.6.0",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "jimp": "^1.6.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "migrate-mongo": "^14.0.7",
    "mongodb": "^7.0.0",
    "mongoose": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nanoid": "^3.3.11",
    "nodemailer": "^7.0.12",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "razorpay": "^2.9.6",
    "sanitize-html": "^2.17.1",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/geoip-lite": "^1.4.4",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^30.0.0",
    "@types/json2csv": "^5.0.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/nanoid": "^2.1.0",
    "@types/node": "^25.1.0",
    "@types/nodemailer": "^7.0.4",
    "@types/sanitize-html": "^2.16.0",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "eslint": "^9.39.2",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^3.15.0",
    "type-fest": "^5.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
