# Esparex Backend Environment Configuration
# Copy this file to .env and fill in your values
# SSOT: core/src/config/env.ts

# ---------------------------------------------------------
# 1. RUNTIME
# ---------------------------------------------------------
NODE_ENV=development
PORT=5001
CI=false
TZ=UTC
# api | scheduler | worker
PROCESS_ROLE=api

# ---------------------------------------------------------
# 2. DATABASE
# ---------------------------------------------------------
MONGODB_URI=mongodb://127.0.0.1:27017/esparex_user
ADMIN_MONGODB_URI=mongodb://127.0.0.1:27017/esparex_user
ALLOW_BOOT_AUTO_INDEX=false
ALLOW_DB_CONNECT=true

# ---------------------------------------------------------
# 3. REDIS
# ---------------------------------------------------------
ALLOW_REDIS=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_URL=
REDIS_DB=0
REDIS_MODE=single

# ---------------------------------------------------------
# 4. AUTHENTICATION
# ---------------------------------------------------------
# SECURITY: Generate a strong secret (64+ chars) for production
JWT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET_AT_LEAST_32_CHARACTERS_LONG
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=
ADMIN_SESSION_TTL_MS=28800000
AUTH_LOCAL_RELAXED=false
ALLOW_DEFAULT_ADMIN_SEED=false

# ---------------------------------------------------------
# 5. OTP & SMS
# ---------------------------------------------------------
OTP_HASH_SECRET=
HMAC_SECRET=super_secret_fallback_key_for_dev_32char
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=
AUTH_BYPASS_OTP_LOCK=false
USE_DEFAULT_OTP=false
DEV_STATIC_OTP=123456

# ---------------------------------------------------------
# 6. COOKIES & SECURITY
# ---------------------------------------------------------
COOKIE_DOMAIN=
# strict | lax | none
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

# ---------------------------------------------------------
# 7. CORS & URLS
# ---------------------------------------------------------
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3000
FRONTEND_INTERNAL_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
ADMIN_FRONTEND_URL=http://localhost:3001

# ---------------------------------------------------------
# 8. UPLOAD STORAGE (S3)
# ---------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=
S3_BUCKET_NAME=
AWS_CLOUDFRONT_URL=
DRY_RUN_S3_CLEANUP=false

# ---------------------------------------------------------
# 9. PAYMENTS
# ---------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---------------------------------------------------------
# 10. NOTIFICATIONS & FIREBASE
# ---------------------------------------------------------
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
ALLOW_FIREBASE_ADMIN=false

# ---------------------------------------------------------
# 11. AI & RISK SCORING
# ---------------------------------------------------------
# gemini | openai
AI_PROVIDER=gemini
GEMINI_API_KEY=
AI_MODEL=
GEMINI_MODEL=
AI_REQUEST_TIMEOUT_MS=30000
AI_MAX_IMAGE_BYTES=10485760
FRAUD_DECISION_TIMEOUT_MS=1200
FRAUD_AUTO_SUSPEND_THRESHOLD=81
PROD_RISK_OVERRIDE=false

# ---------------------------------------------------------
# 12. SEARCH & FEED
# ---------------------------------------------------------
ATLAS_LOCATION_SEARCH_INDEX=location_autocomplete
FEED_DEBUG=false
HOME_FEED_WARM_LOCATIONS=
ENABLE_STRICT_DUPLICATE_INDEX=false
DUPLICATE_ROLLOUT_MIGRATION_TAG=

# ---------------------------------------------------------
# 13. SENTRY
# ---------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_ENABLE_DEV=false

# ---------------------------------------------------------
# 14. EMAIL
# ---------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---------------------------------------------------------
# 15. SCHEDULER & WORKERS
# ---------------------------------------------------------
RUN_SCHEDULERS=false
ENABLE_SCHEDULER=false
ALLOW_SCHEDULER_QUEUE=false

# ---------------------------------------------------------
# 16. RELIABILITY & MONITORING
# ---------------------------------------------------------
RELIABILITY_ALERTS_ENABLED=true
RELIABILITY_SLACK_WEBHOOK_URL=
RELIABILITY_ALERT_EMAIL_TO=
RELIABILITY_ALERT_THROTTLE_MS=300000
RELIABILITY_API_LATENCY_THRESHOLD_MS=750
RELIABILITY_HIGH_ERROR_RATE_THRESHOLD=0.15
RELIABILITY_ERROR_RATE_MIN_REQUESTS=100
RELIABILITY_QUEUE_DELAY_THRESHOLD_MS=60000
RELIABILITY_DB_RESPONSE_THRESHOLD_MS=250
RELIABILITY_SLO_WINDOW_MS=60000
RELIABILITY_SLO_API_MIN_SAMPLES=100
RELIABILITY_SLO_DB_MIN_SAMPLES=6
RELIABILITY_SLO_QUEUE_MIN_SAMPLES=3
RELIABILITY_SLO_RECOVERY_HYSTERESIS_RATIO=0.9
RELIABILITY_QUEUE_FAILURE_SPIKE_THRESHOLD=20
RELIABILITY_QUEUE_FAILURE_WINDOW_MS=60000
RELIABILITY_API_USAGE_SPIKE_THRESHOLD=300
RELIABILITY_API_USAGE_SPIKE_WINDOW_MS=60000
RELIABILITY_RATE_LIMIT_ABUSE_THRESHOLD=25
RELIABILITY_REPEATED_FAILURE_THRESHOLD=20
RELIABILITY_REPEATED_FAILURE_WINDOW_MS=300000
RELIABILITY_WORKER_AUTO_RECOVERY_DELAY_MS=5000
RELIABILITY_WORKER_AUTO_RECOVERY_MAX_ATTEMPTS=3
RELIABILITY_STARTUP_READINESS_TIMEOUT_MS=12000
RELIABILITY_REDIS_RECOVERY_PROBE_TIMEOUT_MS=2000

# ---------------------------------------------------------
# 17. SYSTEM MONITORING
# ---------------------------------------------------------
CONTAINER_MEMORY_LIMIT_MB=
SYSTEM_MONITOR_WARN_RATIO=0.8

# ---------------------------------------------------------
# 18. FEATURE FLAGS
# ---------------------------------------------------------
ENABLE_SWAGGER=true
ENABLE_RATE_LIMITING=true
ADMIN_RATE_LIMIT_MAX=200
ADMIN_MUTATION_RATE_LIMIT_MAX=50
ENABLE_MAINTENANCE_MODE=false

# ---------------------------------------------------------
# 19. BACKUPS
# ---------------------------------------------------------
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_CRON_SCHEDULE=0 2 * * *
ENABLE_AUTO_BACKUPS=false

# ---------------------------------------------------------
# 20. OTHER (OPTIONAL)
# ---------------------------------------------------------
IPAPI_KEY=
