# Esparex Backend - Production Environment Template
# 🚨 SECURITY: All secrets MUST be injected via CI/CD or platform (Render/Vercel)

# 1. RUNTIME
NODE_ENV=production
PORT=10000
TZ=UTC
PROCESS_ROLE=api

# 2. DATABASE
# Use production connection strings with strong passwords
MONGODB_URI=
ADMIN_MONGODB_URI=

# 3. REDIS
ALLOW_REDIS=true
REDIS_URL=
REDIS_MODE=cluster

# 4. AUTHENTICATION
# JWT_SECRET must be 64+ characters in production
JWT_SECRET=
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=

# 5. OTP & SMS
OTP_HASH_SECRET=
HMAC_SECRET=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=
USE_DEFAULT_OTP=false

# 6. COOKIES & SECURITY
COOKIE_DOMAIN=esparex.in
COOKIE_SAME_SITE=lax
COOKIE_SECURE=true

# 7. CORS & URLS
CORS_ORIGIN=https://esparex.in,https://admin.esparex.in
FRONTEND_URL=https://esparex.in
ADMIN_URL=https://admin.esparex.in

# 8. UPLOAD STORAGE (S3)
S3_BUCKET_NAME=
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# 13. SENTRY
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# 16. RELIABILITY
RELIABILITY_ALERTS_ENABLED=true
RELIABILITY_SLACK_WEBHOOK_URL=
RELIABILITY_ALERT_EMAIL_TO=

# 18. FEATURE FLAGS
ENABLE_SWAGGER=false
ENABLE_RATE_LIMITING=true
ADMIN_RATE_LIMIT_MAX=300
ADMIN_MUTATION_RATE_LIMIT_MAX=60
ENABLE_MAINTENANCE_MODE=false
