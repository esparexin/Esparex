# --------------------------------------------------------------------------
# ESPAREX BACKEND - PRODUCTION ENVIRONMENT TEMPLATE
# --------------------------------------------------------------------------
# Copy this to the Render/Railway dashboard. DO NOT commit the real .env file.

NODE_ENV=production
PORT=10000

# MongoDB (Atlas)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/esparex_prod
ADMIN_MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/esparex_prod

# Auth
JWT_SECRET=generate-a-long-random-string-here
ADMIN_JWT_SECRET=generate-another-long-random-string-here
REFRESH_TOKEN_SECRET=generate-third-long-random-string-here
OTP_HASH_SECRET=generate-fourth-long-random-string-here

# Origins
CORS_ORIGIN=https://esparex.in,https://admin.esparex.in
COOKIE_DOMAIN=esparex.in
FRONTEND_URL=https://esparex.in
FRONTEND_INTERNAL_URL=https://esparex.in
ADMIN_URL=https://admin.esparex.in
ADMIN_FRONTEND_URL=https://admin.esparex.in

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=esparex-production

# Firebase (Paste the JSON string from your Service Account file)
FIREBASE_SERVICE_ACCOUNT_JSON=

# MSG91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Redis
REDIS_URL=redis://default:<password>@<host>:6379

# Reliability alerts
RELIABILITY_ALERTS_ENABLED=true
RELIABILITY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
RELIABILITY_ALERT_EMAIL_TO=sre@esparex.in,platform-alerts@esparex.in
RELIABILITY_ALERT_THROTTLE_MS=300000
RELIABILITY_API_LATENCY_THRESHOLD_MS=750
RELIABILITY_HIGH_ERROR_RATE_THRESHOLD=0.15
RELIABILITY_ERROR_RATE_MIN_REQUESTS=100
RELIABILITY_QUEUE_DELAY_THRESHOLD_MS=60000
RELIABILITY_DB_RESPONSE_THRESHOLD_MS=250
RELIABILITY_SLO_WINDOW_MS=60000
RELIABILITY_SLO_API_MIN_SAMPLES=100
RELIABILITY_SLO_DB_MIN_SAMPLES=6
RELIABILITY_SLO_QUEUE_MIN_SAMPLES=3
RELIABILITY_SLO_RECOVERY_HYSTERESIS_RATIO=0.9
RELIABILITY_QUEUE_FAILURE_SPIKE_THRESHOLD=20
RELIABILITY_QUEUE_FAILURE_WINDOW_MS=60000
RELIABILITY_API_USAGE_SPIKE_THRESHOLD=300
RELIABILITY_API_USAGE_SPIKE_WINDOW_MS=60000
RELIABILITY_RATE_LIMIT_ABUSE_THRESHOLD=25
RELIABILITY_REPEATED_FAILURE_THRESHOLD=20
RELIABILITY_REPEATED_FAILURE_WINDOW_MS=300000
RELIABILITY_WORKER_AUTO_RECOVERY_DELAY_MS=5000
RELIABILITY_WORKER_AUTO_RECOVERY_MAX_ATTEMPTS=3
RELIABILITY_STARTUP_READINESS_TIMEOUT_MS=12000
RELIABILITY_REDIS_RECOVERY_PROBE_TIMEOUT_MS=2000

# Safety
USE_DEFAULT_OTP=false
PROD_RISK_OVERRIDE=false
# PROCESS_ROLE: api | scheduler | worker
RUN_SCHEDULERS=false
ENABLE_SCHEDULER=false
PROCESS_ROLE=api
