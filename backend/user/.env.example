# Esparex Backend Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED CONFIGURATION
# ============================================

# Node Environment (development | production | test)
NODE_ENV=development

# Server Port
PORT=5001

# MongoDB Connection Strings
# User database (ads, users, businesses)
MONGODB_URI=mongodb://127.0.0.1:27017/esparex_user

# Admin database (master data: categories, brands, models)
# NOTE: To enable native populate() features, point this to the SAME database as MONGODB_URI
ADMIN_MONGODB_URI=mongodb://127.0.0.1:27017/esparex_user

# JWT Authentication
# 🚨 SECURITY: Generate a strong secret for production!
# Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET_AT_LEAST_32_CHARACTERS_LONG
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
ADMIN_JWT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET_AT_LEAST_32_CHARACTERS_LONG
REFRESH_TOKEN_SECRET=CHANGE_ME_TO_A_STRONG_SECRET_AT_LEAST_32_CHARACTERS_LONG
OTP_HASH_SECRET=CHANGE_ME_TO_A_STRONG_SECRET_AT_LEAST_32_CHARACTERS_LONG

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
COOKIE_DOMAIN=
FRONTEND_URL=http://localhost:3000
FRONTEND_INTERNAL_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
ADMIN_FRONTEND_URL=http://localhost:3001
# Production example:
# CORS_ORIGIN=https://exparex.in,https://admin.exparex.in
# COOKIE_DOMAIN=exparex.in
# FRONTEND_URL=https://exparex.in
# FRONTEND_INTERNAL_URL=https://exparex.in
# ADMIN_URL=https://admin.exparex.in
# ADMIN_FRONTEND_URL=https://admin.exparex.in

# ============================================
# OPTIONAL CONFIGURATION
# ============================================

# AWS S3 (for image uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=

# Firebase (for push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=

# MSG91 (for OTP)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
MSG91_TEMPLATE_ID=

# OTP shortcuts (development only)
# Enable these only in backend/.env.local on your own machine.
# Production must keep USE_DEFAULT_OTP=false and use the real SMS provider.
USE_DEFAULT_OTP=false
DEV_STATIC_OTP=123456

# Google Gemini AI (for content moderation)
GEMINI_API_KEY=

# Razorpay (for payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Redis (for caching and rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Production should use REDIS_URL. Local development can continue to use host/port/password.
REDIS_URL=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Sentry (error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Reliability alerts (Slack + Email fallback)
RELIABILITY_ALERTS_ENABLED=true
RELIABILITY_SLACK_WEBHOOK_URL=
RELIABILITY_ALERT_EMAIL_TO=
RELIABILITY_ALERT_THROTTLE_MS=300000
RELIABILITY_API_LATENCY_THRESHOLD_MS=750
RELIABILITY_HIGH_ERROR_RATE_THRESHOLD=0.15
RELIABILITY_ERROR_RATE_MIN_REQUESTS=100
RELIABILITY_QUEUE_DELAY_THRESHOLD_MS=60000
RELIABILITY_DB_RESPONSE_THRESHOLD_MS=250
RELIABILITY_SLO_WINDOW_MS=60000
RELIABILITY_SLO_API_MIN_SAMPLES=100
RELIABILITY_SLO_DB_MIN_SAMPLES=6
RELIABILITY_SLO_QUEUE_MIN_SAMPLES=3
RELIABILITY_SLO_RECOVERY_HYSTERESIS_RATIO=0.9
RELIABILITY_QUEUE_FAILURE_SPIKE_THRESHOLD=20
RELIABILITY_QUEUE_FAILURE_WINDOW_MS=60000
RELIABILITY_API_USAGE_SPIKE_THRESHOLD=300
RELIABILITY_API_USAGE_SPIKE_WINDOW_MS=60000
RELIABILITY_RATE_LIMIT_ABUSE_THRESHOLD=25
RELIABILITY_REPEATED_FAILURE_THRESHOLD=20
RELIABILITY_REPEATED_FAILURE_WINDOW_MS=300000
RELIABILITY_WORKER_AUTO_RECOVERY_DELAY_MS=5000
RELIABILITY_WORKER_AUTO_RECOVERY_MAX_ATTEMPTS=3
RELIABILITY_STARTUP_READINESS_TIMEOUT_MS=12000
RELIABILITY_REDIS_RECOVERY_PROBE_TIMEOUT_MS=2000

# ============================================
# FEATURE FLAGS
# ============================================

# Enable Swagger API documentation
ENABLE_SWAGGER=true

# Enable rate limiting
ENABLE_RATE_LIMITING=true

# Enable maintenance mode (blocks all requests)
ENABLE_MAINTENANCE_MODE=false

# Runtime management
# PROCESS_ROLE: api | scheduler | worker
# - api: serves HTTP API only (schedulers disabled in production)
# - scheduler: serves API + cron/scheduler jobs
# - worker: background queue workers (no HTTP listener)
RUN_SCHEDULERS=false
ENABLE_SCHEDULER=false
PROCESS_ROLE=api
TZ=UTC

# ============================================
# BACKUP CONFIGURATION
# ============================================

# Directory for database backups
BACKUP_DIR=./backups

# Backup retention period (days)
BACKUP_RETENTION_DAYS=30

# Cron schedule for automated backups (default: 2 AM daily)
# Format: minute hour day month weekday
BACKUP_CRON_SCHEDULE=0 2 * * *

# Enable automated backups (recommended for production)
ENABLE_AUTO_BACKUPS=false

# Timezone for backup cron jobs
# Uses TZ from runtime management section above.

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before deploying to production, ensure:
# ✅ JWT_SECRET is a strong, randomly generated secret (64+ characters)
# ✅ MONGODB_URI points to production database with authentication
# ✅ All external service credentials are configured
# ✅ SENTRY_DSN is configured for error tracking
# ✅ CORS_ORIGIN is set to production domain
# ✅ ENABLE_SWAGGER is set to false (or protected)
# ✅ Redis is configured for production
# ✅ Backup strategy is in place
