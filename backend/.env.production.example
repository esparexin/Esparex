# --------------------------------------------------------------------------
# ESPAREX BACKEND - PRODUCTION ENVIRONMENT TEMPLATE
# --------------------------------------------------------------------------
# Copy this to the Render/Railway dashboard. DO NOT commit the real .env file.

NODE_ENV=production
PORT=10000

# MongoDB (Atlas)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/esparex_prod
ADMIN_MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/esparex_prod

# Auth
JWT_SECRET=generate-a-long-random-string-here
ADMIN_JWT_SECRET=generate-another-long-random-string-here
REFRESH_TOKEN_SECRET=generate-third-long-random-string-here
OTP_HASH_SECRET=generate-fourth-long-random-string-here

# Origins
CORS_ORIGIN=https://esparex.in,https://admin.esparex.in
COOKIE_DOMAIN=esparex.in
FRONTEND_URL=https://esparex.in
FRONTEND_INTERNAL_URL=https://esparex.in
ADMIN_URL=https://admin.esparex.in
ADMIN_FRONTEND_URL=https://admin.esparex.in

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=esparex-production

# Firebase (Paste the JSON string from your Service Account file)
FIREBASE_SERVICE_ACCOUNT_JSON=

# MSG91
MSG91_AUTH_KEY=
MSG91_SENDER_ID=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Redis
REDIS_URL=redis://default:<password>@<host>:6379

# Safety
USE_DEFAULT_OTP=false
