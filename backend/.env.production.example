# Esparex Production Environment Template
# Copy this to .env.production on your server and FILL IN THE VALUES

# ------------------------------------------------------------------------------
# CORE
# ------------------------------------------------------------------------------
PORT=5001
NODE_ENV=production
# ------------------------------------------------------------------------------
# AUTH & SECURITY
# ------------------------------------------------------------------------------
JWT_SECRET=your_long_random_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
CORS_ORIGIN=https://esparex.com

# ------------------------------------------------------------------------------
# DATABASE
# ------------------------------------------------------------------------------
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/database
MONGODB_URI=
ADMIN_MONGODB_URI=

# ------------------------------------------------------------------------------
# AWS S3 (For Images)
# ------------------------------------------------------------------------------
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# ------------------------------------------------------------------------------
# EXTERNAL APIS & SERVICES
# ------------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
SENTRY_DSN=
GEMINI_API_KEY=

# SMS (MSG91)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=

# Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ------------------------------------------------------------------------------
# EMAIL (SMTP)
# ------------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@esparex.com

# ------------------------------------------------------------------------------
# FIREBASE (For Push Notifications)
# ------------------------------------------------------------------------------
# 1. Admin SDK: Provide the full JSON string of your service account key file
FIREBASE_SERVICE_ACCOUNT_JSON=

# 2. Client SDK (Required for firebase.ts in backend)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ------------------------------------------------------------------------------
# SYSTEM & FEATURE FLAGS
# ------------------------------------------------------------------------------
ENABLE_SWAGGER=true
ENABLE_RATE_LIMITING=true
ENABLE_MAINTENANCE_MODE=false
