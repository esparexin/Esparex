{
  "threshold": 2.5,
  "minLines": 8,
  "minTokens": 100,
  "languages": ["typescript", "tsx"],
  "path": [
    "backend/api/src",
    "apps/web/src",
    "apps/admin/src",
    "core/src",
    "shared",
    "packages"
  ],
  "ignore": [
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**",
    "**/coverage/**",
    "**/.turbo/**",
    "**/.scratch/**",
    "**/.agents/**",
    "**/.venv/**",
    "**/test-results/**",
    "**/playwright-report/**",
    "**/__snapshots__/**",
    "**/*.snap",
    "**/.eslintcache",
    "**/storybook-static/**",
    "**/public/build/**",
    "**/*.d.ts",
    "**/__tests__/**",
    "**/__mocks__/**",
    "**/.jscpd-report/**",
    ".jscpd-report/**",
    "**/scripts/**",
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  "reporters": ["console", "json"],
  "output": ".jscpd-report"
}
