{
  "threshold": 2.5,
  "minLines": 8,
  "minTokens": 100,
  "languages": ["typescript", "tsx"],
  "path": [
    "user-backend/src",
    "admin-backend/src",
    "apps/web/src",
    "admin-frontend/src",
    "core/src",
    "shared"
  ],
  "ignore": [
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/*.d.ts",
    "**/__tests__/**",
    "**/__mocks__/**",
    "**/.claude/**",
    ".claude/**",
    "**/.jscpd-report/**",
    ".jscpd-report/**",
    "**/scripts/**",
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  "reporters": ["console", "json"],
  "output": ".jscpd-report"
}
