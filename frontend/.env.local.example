# Firebase Configuration
# Copy this file to .env.local and fill in your values

# Get these values from Firebase Console > Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-web-push-vapid-key

# Encryption
NEXT_PUBLIC_ENCRYPTION_KEY=your-strong-random-key-here

# Environment & API
NEXT_PUBLIC_API_URL=http://localhost:5001/api/v1
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:5001/api/admin
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Development Flags
NEXT_PUBLIC_USE_DEFAULT_OTP=true
NEXT_PUBLIC_LOCAL_DEV_AUTH=false

# Mobile wrapper note:
# Do not use localhost values for real Android/iPhone builds.
# Capacitor should point to a real HTTPS user app origin, for example:
# CAPACITOR_SERVER_URL=https://app-staging.esparex.com

# Server-side Firebase (for admin operations)
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
# FIREBASE_VAPID_KEY=your-vapid-key-here
