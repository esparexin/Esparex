# Production Configuration
# Update these values for your production environment

# API Configuration
NEXT_PUBLIC_API_URL=https://api.esparex.com/api/v1
NEXT_PUBLIC_APP_URL=https://esparex.com

# Development Features (DISABLED in production)
NEXT_PUBLIC_LOCAL_DEV_AUTH=false
NEXT_PUBLIC_USE_DEFAULT_OTP=false

# Firebase Configuration (Production)
# Replace with your production Firebase project
NEXT_PUBLIC_FIREBASE_API_KEY=your-production-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-production-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-production-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-production-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-web-push-vapid-key

# Optional: Firebase Analytics (Production)
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Mobile wrapper note:
# Use a hosted HTTPS user app for Capacitor server.url.
# Example:
# CAPACITOR_SERVER_URL=https://app.esparex.com
