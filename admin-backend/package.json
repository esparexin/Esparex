{
  "name": "admin-backend",
  "version": "1.0.0",
  "description": "Administrative Backend for Esparex",
  "main": "index.js",
  "engines": {
    "node": ">=24.0.0 <26",
    "npm": ">=11.8.0 <12"
  },
  "scripts": {
    "clean": "lsof -ti:5001 | xargs kill -9 || true",
    "predev": "npm run clean",
    "start": "NODE_ENV=production node dist/admin-backend/src/server.js",
    "start:dev": "node dist/admin-backend/src/server.js",
    "start:ts": "ts-node --files -r tsconfig-paths/register src/server.ts",
    "dev": "nodemon",
    "build": "rm -rf dist && tsc && npx tsc-alias",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@esparex/core": "*",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.2",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.1.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^3.15.0",
    "typescript": "^5.9.3"
  }
}
