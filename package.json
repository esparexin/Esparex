{
  "name": "esparex-admin-root",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.8.0",
  "engines": {
    "node": ">=24.0.0 <26",
    "npm": ">=11.8.0 <12"
  },
  "workspaces": [
    "user-backend",
    "admin-backend",
    "core",
    "user-frontend",
    "admin-frontend",
    "shared",
    "shared/observability",
    "apps/mobile-app"
  ],
  "scripts": {
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "release:major": "standard-version --release-as major",
    "release:dry-run": "standard-version --dry-run",
    "precheck": "npm run build && ./scripts/ci-guard.sh",
    "prepare": "husky",
    "hooks:install": "bash scripts/install-git-hooks.sh",
    "clean:workspace-installs": "rm -rf user-backend/node_modules user-frontend/node_modules admin-frontend/node_modules shared/node_modules",
    "build": "npm run build -w @esparex/shared && npm run build -w @shared/observability && npm run build -w @esparex/core && npm run build -w @esparex/user-backend && npm run build -w @esparex/admin-backend && npm run build -w @esparex/user-frontend && npm run build -w @esparex/admin-frontend",
    "type-check": "npm run type-check -w @esparex/shared && npm run type-check -w @esparex/core && npm run type-check -w @esparex/user-backend && npm run type-check -w @esparex/admin-backend && npm run type-check -w @esparex/user-frontend && npm run type-check -w @esparex/admin-frontend",
    "dev:all": "concurrently \"npm run dev -w @esparex/user-backend\" \"npm run dev -w @esparex/admin-backend\"",
    "lint:no-api-string-literals": "node scripts/enforce-no-api-string-literals.js",
    "guard:component-api-boundary": "node scripts/enforce-component-api-boundary.js",
    "guard:compatibility-markers": "node scripts/enforce-compatibility-markers-baseline.js",
    "guard:route-collision": "node scripts/enforce-route-collision-guard.js",
    "guard:route-hierarchy": "node scripts/guard-route-shadowing.js",
    "guard:ad-ssot": "node scripts/enforce-ad-ssot-guard.js",
    "guard:platform-governance": "node scripts/guard-platform-governance.js && node scripts/enforce-compatibility-markers-baseline.js && node scripts/enforce-component-api-boundary.js && node scripts/enforce-ai-governance-ssot.js && node scripts/enforce-no-ad-hard-delete.js && node scripts/enforce-moderation-route-whitelist.js",
    "guard:ai-governance": "node scripts/enforce-ai-governance-ssot.js",
    "guard:no-ad-hard-delete": "node scripts/enforce-no-ad-hard-delete.js",
    "guard:moderation-namespace": "node scripts/enforce-moderation-route-whitelist.js",
    "guard:schema-migration": "bash scripts/enforce-schema-migration-gate.sh",
    "guard:pr-impact-analysis": "node scripts/enforce-pr-impact-analysis.js",
    "ci:image-domains": "npm run ci:image-domains -w @esparex/user-frontend",
    "lint:admin-status:ssot": "node scripts/enforce-admin-status-literals.js",
    "lint:user-api-result:ssot": "node scripts/enforce-user-api-result-ssot.js",
    "contract:user-api": "node scripts/verify-api-contract.js --scope=user",
    "contract:admin-api": "node scripts/verify-api-contract.js --scope=admin",
    "contract:api": "node scripts/verify-api-contract.js --scope=both",
    "guard:api-ssot": "npm run lint:no-api-string-literals",
    "contract:error-envelope": "node scripts/enforce-error-response-contract.js",
    "audit:orphans": "node scripts/orphan-sweep.cjs",
    "ci:admin-guardrails": "npm run ci:guardrails -w @esparex/admin-frontend",
    "check:s3-images": "npx ts-node --compiler-options '{\"moduleResolution\":\"NodeNext\"}' scripts/check-s3-images.ts",
    "lint": "node scripts/run-eslint-changed.js",
    "guard:unused-imports": "node scripts/enforce-no-new-unused-imports.js",
    "guard:duplication": "npx jscpd --config .jscpd.json",
    "guard:api-surface": "node scripts/enforce-api-surface-guard.js",
    "ci:check": "tsc --build --noEmit && npx syncpack list-mismatches && npm ls",
    "mobile:sync": "STATIC_EXPORT=true npm run build -w @esparex/user-frontend && node scripts/guard-mobile-build.js && npm run sync -w @esparex/mobile-app",
    "mobile:build:android": "npm run mobile:sync && npm run build:android -w @esparex/mobile-app",
    "mobile:build:ios": "npm run mobile:sync && npm run build:ios -w @esparex/mobile-app"
  },
  "optionalDependencies": {
    "@emnapi/runtime": "^1.8.1"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "http-proxy-agent": {
      "@tootallnate/once": "^3.0.1"
    },
    "handlebars": "^4.7.9",
    "socket.io-parser": "^4.2.6"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@types/validator": "^13.15.10",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "madge": "^8.0.0",
    "pm2": "^6.0.14",
    "standard-version": "^9.5.0",
    "syncpack": "^13.0.4",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "module-alias": "^2.3.4"
  }
}
