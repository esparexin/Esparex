{
  "name": "esparex-admin-root",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "packageManager": "npm@10.9.7",
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend/api",
    "core",
    "shared"
  ],
  "scripts": {
    "prepare": "node -e \"const e=process.env,fs=require('fs');if(!e.CI&&!e.VERCEL&&!e.RENDER&&fs.existsSync('.git')){require('child_process').execSync('husky',{stdio:'inherit'})}\"",
    "hooks:install": "husky install",
    "clean:workspace-installs": "node -e \"['backend/api/node_modules', 'apps/admin/node_modules', 'apps/web/node_modules', 'shared/node_modules', 'core/node_modules'].forEach(p => require('fs').rmSync(p, { recursive: true, force: true }))\"",
    "build": "npm run build -w @esparex/contracts && npm run build -w @esparex/shared && npm run build -w @esparex/core && npm run build -w @esparex/backend-api && npm run build -w @esparex/apps-admin && npm run build -w @esparex/apps-web",
    "type-check": "npm run type-check -w @esparex/contracts && npm run type-check -w @esparex/shared && npm run type-check -w @esparex/core && npm run type-check -w @esparex/backend-api && npm run type-check -w @esparex/apps-admin && npm run type-check -w @esparex/apps-web",
    "dev:all": "concurrently \"npm run dev -w @esparex/backend-api\" \"npm run dev -w @esparex/apps-admin\" \"npm run dev -w @esparex/apps-web\"",
    "lint:no-api-string-literals": "node scripts/enforce-no-api-string-literals.js",
    "guard:component-api-boundary": "node scripts/enforce-component-api-boundary.js",
    "guard:compatibility-markers": "node scripts/enforce-compatibility-markers-baseline.js",
    "guard:route-collision": "node scripts/enforce-route-collision-guard.js",
    "guard:route-hierarchy": "node scripts/guard-route-shadowing.js",
    "guard:ad-ssot": "node scripts/enforce-ad-ssot-guard.js",
    "guard:platform-governance": "node scripts/guard-platform-governance.js && node scripts/enforce-compatibility-markers-baseline.js && node scripts/enforce-component-api-boundary.js && node scripts/enforce-agents-ssot.js && node scripts/enforce-no-ad-hard-delete.js && node scripts/enforce-moderation-route-whitelist.js && node scripts/enforce-notification-governance.js",
    "guard:ai-governance": "node scripts/enforce-agents-ssot.js",
    "guard:no-ad-hard-delete": "node scripts/enforce-no-ad-hard-delete.js",
    "guard:moderation-namespace": "node scripts/enforce-moderation-route-whitelist.js",
    "guard:schema-migration": "node scripts/enforce-schema-migration-gate.js",
    "guard:pr-impact-analysis": "node scripts/enforce-pr-impact-analysis.js",
    "lint:admin-status:ssot": "node scripts/enforce-admin-status-literals.js",
    "lint:user-api-result:ssot": "node scripts/enforce-user-api-result-ssot.js",
    "contract:user-api": "node scripts/verify-api-contract.js --scope=user",
    "contract:admin-api": "node scripts/verify-api-contract.js --scope=admin",
    "contract:api": "node scripts/verify-api-contract.js --scope=both",
    "guard:api-ssot": "npm run lint:no-api-string-literals",
    "guard:runtime-parity": "node scripts/guard-runtime-parity.js",
    "guard:core-export-parity": "node scripts/guard-core-export-parity.js",
    "contract:error-envelope": "node scripts/enforce-error-response-contract.js",
    "ci:admin-guardrails": "npm run ci:guardrails -w @esparex/apps-admin",
    "check:s3-images": "npx ts-node --compiler-options '{\"moduleResolution\":\"NodeNext\"}' scripts/check-s3-images.ts",
    "lint:admin": "eslint apps/admin --cache --cache-location .eslintcache/admin",
    "lint:web": "eslint apps/web --cache --cache-location .eslintcache/web",
    "lint:backend": "eslint backend --cache --cache-location .eslintcache/backend",
    "lint:core": "eslint core --cache --cache-location .eslintcache/core",
    "lint:shared": "eslint shared --cache --cache-location .eslintcache/shared",
    "lint": "eslint .",
    "lint:fast": "eslint . --cache",
    "lint:ci": "eslint -f json -o ci-lint-results.json . && node scripts/lint-baseline-enforcement.js ci-lint-results.json",
    "lint:changed": "node scripts/run-eslint-changed.js",
    "lint:fix": "eslint . --fix",
    "test": "npm test -w @esparex/backend-api && npm test -w @esparex/core",
    "e2e": "node scripts/run-deterministic-e2e.mjs",
    "e2e:listing-edit": "npm run e2e:listing-edit -w @esparex/apps-web",
    "e2e:listing-edit:ci": "npm run e2e:listing-edit:ci -w @esparex/apps-web",
    "ci:strict": "npm run lint:ci && npm run type-check && npm run test",
    "ci:governance": "node scripts/lint-baseline-enforcement.js ci-lint-results.json",
    "guard:unused-imports": "node scripts/enforce-no-new-unused-imports.js",
    "guard:duplicate-code": "jscpd --config .jscpd.json",
    "guard:circular": "madge --circular --extensions ts core/src backend/api/src",
    "guard:dependencies": "depcruise --config .dependency-cruiser.js core backend/api",
    "guard:dead-code": "node scripts/orphan-sweep.cjs",
    "guard:knip": "knip --no-exit-code --no-config-hints",
    "guard:generated-artifacts": "node scripts/guard-generated-artifacts.js",
    "audit:duplicates": "node scripts/catalog-governance-audit.js duplicates",
    "audit:orphans": "node scripts/catalog-governance-audit.js orphans",
    "audit:canonical": "node scripts/catalog-governance-audit.js canonical",
    "audit:status": "node scripts/catalog-governance-audit.js status",
    "audit:pollution": "node scripts/catalog-governance-audit.js pollution",
    "audit:catalog-governance": "node scripts/catalog-governance-audit.js all",
    "catalog:stabilize": "node scripts/catalog-stabilization.js",
    "catalog:stabilize:apply": "node scripts/catalog-stabilization.js --apply",
    "catalog:stabilize:apply-duplicates": "node scripts/catalog-stabilization.js --apply --include-duplicates",
    "catalog:index-migration": "node scripts/catalog-index-migration.js",
    "catalog:index-migration:apply": "node scripts/catalog-index-migration.js --apply",
    "catalog:index-migration:rollback": "node scripts/catalog-index-migration.js --rollback",
    "guard:naming": "node scripts/enforce-file-naming-conventions.js",
    "guard:objectid": "node scripts/enforce-objectid-validation.js",
    "guard:notification-governance": "node scripts/enforce-notification-governance.js",
    "guard:admin-status-literals": "node scripts/enforce-admin-status-literals.js",
    "guard:api-surface": "node scripts/enforce-api-surface-guard.js",
    "guard:license": "license-checker --summary --production",
    "guard:audit": "npm audit --audit-level=critical",
    "guard:buildgraph": "node scripts/git/esparex/buildgraph-validator.js",
    "governance:guards": "npm run guard:buildgraph && npm run guard:naming && npm run guard:objectid && npm run guard:platform-governance && npm run guard:notification-governance && npm run guard:ad-ssot && npm run guard:admin-status-literals && npm run guard:api-surface && npm run guard:component-api-boundary && npm run guard:compatibility-markers && npm run guard:generated-artifacts",
    "governance:all": "npm run lint && npm run type-check && npm run guard:dependencies && npm run guard:circular && npm run guard:duplicate-code && npm run guard:dead-code && npm run guard:knip && npm run guard:license && npm run governance:guards && npm run test && npm run build",
    "guard:env-contracts": "node scripts/guard-env-contracts.js",
    "debt:baseline": "cross-env NODE_OPTIONS=--max-old-space-size=8192 node scripts/generate-eslint-baseline.js",
    "debt:insights": "node scripts/analyze-tech-debt.js",
    "repo:workspace": "node scripts/git/workspace-check.js",
    "repo:secret": "node scripts/git/secret-scan.js",
    "repo:binary": "node scripts/git/binary-check.js",
    "repo:lockfile": "node scripts/git/lockfile-check.js",
    "repo:branch-protection": "node scripts/git/esparex/branch-protection.js",
    "repo:routes": "node scripts/git/esparex/route-validator.js",
    "repo:contracts": "node scripts/git/esparex/contract-validator.js",
    "repo:env-vars": "node scripts/git/esparex/env-validator.js",
    "repo:ssot": "node scripts/git/esparex/ssot-validator.js",
    "repo:architecture": "node scripts/git/esparex/architecture-validator.js",
    "repo:gate": "node scripts/git/repo-gate.js",
    "architecture": "npx tsx tooling/architecture/index.ts",
    "architecture:changed": "npx tsx tooling/architecture/index.ts --changed",
    "generate:domain": "npx tsx tooling/architecture/generate-domain.ts",
    "verify:architecture": "npx tsx tooling/architecture/verify-architecture.ts"
  },
  "optionalDependencies": {
    "@emnapi/runtime": "^1.8.1"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "http-proxy-agent": {
      "@tootallnate/once": "^3.0.1"
    },
    "handlebars": "^4.7.9",
    "socket.io-parser": "^4.2.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@next/eslint-plugin-next": "^16.2.4",
    "@types/js-yaml": "^4.0.9",
    "@types/validator": "^13.15.10",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "dependency-cruiser": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.9",
    "knip": "^6.26.0",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "pm2": "^6.0.14",
    "semantic-release": "^25.0.5",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.23.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "npm run lint:changed --"
    ]
  }
}
