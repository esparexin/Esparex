{
  "name": "esparex-admin-root",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23"
  },
  "packageManager": "npm@10.9.7",
  "workspaces": [
    "apps/admin",
    "apps/web",
    "backend/user",
    "core",
    "shared",
    "packages/repository-governance",
    "packages/repository-brain",
    "packages/repository-scanner",
    "packages/repository-skills",
    "packages/repository-intelligence",
    "packages/repository-plugin-sdk",
    "packages/repository-plugin-security",
    "packages/repository-plugin-nextjs",
    "packages/repository-runtime"
  ],
  "scripts": {
    "prepare": "node -e \"try { require('child_process').execSync('husky install', {stdio: 'inherit'}) } catch (e) {}\"",
    "hooks:install": "husky install",
    "clean:workspace-installs": "node -e \"['backend/user/node_modules', 'apps/admin/node_modules', 'apps/web/node_modules', 'shared/node_modules', 'core/node_modules'].forEach(p => require('fs').rmSync(p, { recursive: true, force: true }))\"",
    "deploy:gate": "node scripts/ops/deploy-gate.js",
    "setup:dev": "npm run db:seed -w @esparex/backend-user",
    "reset:dev": "node scripts/ops/reset-dev.js && npm run setup:dev",
    "build": "npm run build -w @esparex/shared && npm run build -w @esparex/repository-scanner && npm run build -w @esparex/repository-brain && npm run build -w @esparex/repository-skills && npm run build -w @esparex/repository-governance && npm run build -w @esparex/repository-intelligence && npm run build -w @esparex/repository-plugin-sdk && npm run build -w @esparex/repository-plugin-security && npm run build -w @esparex/repository-plugin-nextjs && npm run build -w @esparex/repository-runtime && npm run build -w @esparex/core && npm run build -w @esparex/backend-user && npm run build -w @esparex/apps-admin && npm run build -w @esparex/apps-web",
    "type-check": "npm run type-check -w @esparex/shared && npm run type-check -w @esparex/repository-scanner && npm run type-check -w @esparex/repository-brain && npm run type-check -w @esparex/repository-skills && npm run type-check -w @esparex/repository-governance && npm run type-check -w @esparex/repository-intelligence && npm run type-check -w @esparex/repository-plugin-sdk && npm run type-check -w @esparex/repository-plugin-security && npm run type-check -w @esparex/repository-plugin-nextjs && npm run type-check -w @esparex/repository-runtime && npm run type-check -w @esparex/core && npm run type-check -w @esparex/backend-user && npm run type-check -w @esparex/apps-admin && npm run type-check -w @esparex/apps-web",
    "dev:all": "concurrently \"npm run dev -w @esparex/backend-user\" \"npm run dev -w @esparex/apps-admin\" \"npm run dev -w @esparex/apps-web\"",
    "lint:no-api-string-literals": "node scripts/enforce-no-api-string-literals.js",
    "guard:component-api-boundary": "node scripts/enforce-component-api-boundary.js",
    "guard:compatibility-markers": "node scripts/enforce-compatibility-markers-baseline.js",
    "guard:route-collision": "node scripts/enforce-route-collision-guard.js",
    "guard:route-hierarchy": "node scripts/guard-route-shadowing.js",
    "guard:ad-ssot": "node scripts/enforce-ad-ssot-guard.js",
    "guard:platform-governance": "node scripts/guard-platform-governance.js && node scripts/enforce-compatibility-markers-baseline.js && node scripts/enforce-component-api-boundary.js && node scripts/enforce-ai-governance-ssot.js && node scripts/enforce-no-ad-hard-delete.js && node scripts/enforce-moderation-route-whitelist.js && node scripts/enforce-notification-governance.js",
    "guard:ai-governance": "node scripts/enforce-ai-governance-ssot.js",
    "guard:no-ad-hard-delete": "node scripts/enforce-no-ad-hard-delete.js",
    "guard:moderation-namespace": "node scripts/enforce-moderation-route-whitelist.js",
    "guard:schema-migration": "node scripts/enforce-schema-migration-gate.js",
    "guard:pr-impact-analysis": "node scripts/enforce-pr-impact-analysis.js",
    "lint:admin-status:ssot": "node scripts/enforce-admin-status-literals.js",
    "lint:user-api-result:ssot": "node scripts/enforce-user-api-result-ssot.js",
    "contract:user-api": "node scripts/verify-api-contract.js --scope=user",
    "contract:admin-api": "node scripts/verify-api-contract.js --scope=admin",
    "contract:api": "node scripts/verify-api-contract.js --scope=both",
    "guard:api-ssot": "npm run lint:no-api-string-literals",
    "guard:runtime-parity": "node scripts/guard-runtime-parity.js",
    "guard:core-export-parity": "node scripts/guard-core-export-parity.js",
    "contract:error-envelope": "node scripts/enforce-error-response-contract.js",
    "ci:admin-guardrails": "npm run ci:guardrails -w @esparex/apps-admin",
    "check:s3-images": "npx ts-node --compiler-options '{\"moduleResolution\":\"NodeNext\"}' scripts/check-s3-images.ts",
    "lint:admin": "eslint apps/admin --cache --cache-location .eslintcache/admin",
    "lint:web": "eslint apps/web --cache --cache-location .eslintcache/web",
    "lint:backend": "eslint backend --cache --cache-location .eslintcache/backend",
    "lint:core": "eslint core --cache --cache-location .eslintcache/core",
    "lint:shared": "eslint shared --cache --cache-location .eslintcache/shared",
    "lint": "eslint .",
    "lint:fast": "eslint . --cache",
    "lint:ci": "eslint . --max-warnings=0",
    "lint:changed": "node scripts/run-eslint-changed.js",
    "lint:fix": "eslint . --fix",
    "test": "npm test -w @esparex/repository-governance && npm test -w @esparex/backend-user && npm test -w @esparex/core",
    "e2e": "node scripts/run-deterministic-e2e.mjs",
    "e2e:listing-edit": "npm run e2e:listing-edit -w @esparex/apps-web",
    "e2e:listing-edit:ci": "npm run e2e:listing-edit:ci -w @esparex/apps-web",
    "ci:strict": "npm run lint:ci && npm run type-check && npm run test",
    "ci:governance": "node scripts/lint-baseline-enforcement.js ci-lint-results.json",
    "guard:unused-imports": "node scripts/enforce-no-new-unused-imports.js",
    "guard:duplicate-code": "jscpd --config .jscpd.json",
    "guard:dead-code": "node scripts/orphan-sweep.cjs",
    "audit:duplicates": "node scripts/catalog-governance-audit.js duplicates",
    "audit:orphans": "node scripts/catalog-governance-audit.js orphans",
    "audit:canonical": "node scripts/catalog-governance-audit.js canonical",
    "audit:status": "node scripts/catalog-governance-audit.js status",
    "audit:pollution": "node scripts/catalog-governance-audit.js pollution",
    "audit:catalog-governance": "node scripts/catalog-governance-audit.js all",
    "catalog:stabilize": "node scripts/catalog-stabilization.js",
    "catalog:stabilize:apply": "node scripts/catalog-stabilization.js --apply",
    "catalog:stabilize:apply-duplicates": "node scripts/catalog-stabilization.js --apply --include-duplicates",
    "catalog:index-migration": "node scripts/catalog-index-migration.js",
    "catalog:index-migration:apply": "node scripts/catalog-index-migration.js --apply",
    "catalog:index-migration:rollback": "node scripts/catalog-index-migration.js --rollback",
    "docs:lint": "node scripts/check-doc-duplicates.js",
    "guard:naming": "node scripts/enforce-file-naming-conventions.js",
    "guard:objectid": "node scripts/enforce-objectid-validation.js",
    "guard:notification-governance": "node scripts/enforce-notification-governance.js",
    "guard:admin-status-literals": "node scripts/enforce-admin-status-literals.js",
    "guard:api-surface": "node scripts/enforce-api-surface-guard.js",
    "governance:guards": "npm run docs:lint && npm run guard:naming && npm run guard:objectid && npm run guard:platform-governance && npm run guard:notification-governance && npm run guard:ad-ssot && npm run guard:admin-status-literals && npm run guard:api-surface && npm run guard:component-api-boundary && npm run guard:compatibility-markers && npm run repository:doctor -- --profile ci",
    "governance:all": "npm run lint && npm run type-check && npm run test && npm run build && npm run guard:duplicate-code && npm run guard:dead-code && npm run governance:guards",
    "architecture:check": "node scripts/architecture/check-architecture.js",
    "architecture:check:fast": "node scripts/architecture/check-architecture.js --fast",
    "architecture:report": "node scripts/architecture/check-architecture.js --report",
    "architecture:generate": "node scripts/architecture/generate-depcruiser.js && node scripts/architecture/generate-eslint-boundaries.js",
    "architecture:visualize": "npx depcruise --config .dependency-cruiser.cjs --collapse \"^core/src/[^/]+\" --output-type html --output-to docs/architecture/dependency-graph.html core/src",
    "architecture:drift": "node scripts/architecture/drift-detector.js",
    "architecture:dashboard": "node scripts/architecture/generate-dashboard.js",
    "api:diff": "node scripts/architecture/api-diff.js",
    "guard:env-contracts": "node scripts/guard-env-contracts.js",
    "guard:unicode-hygiene": "npm run repository:doctor -- --profile ci",
    "repository:doctor": "node packages/repository-governance/dist/cli/index.js",
    "debt:baseline": "cross-env NODE_OPTIONS=--max-old-space-size=8192 node scripts/generate-eslint-baseline.js",
    "debt:insights": "node scripts/analyze-tech-debt.js"
  },
  "optionalDependencies": {
    "@emnapi/runtime": "^1.8.1"
  },
  "overrides": {
    "@tootallnate/once": "^3.0.1",
    "http-proxy-agent": {
      "@tootallnate/once": "^3.0.1"
    },
    "handlebars": "^4.7.9",
    "socket.io-parser": "^4.2.6"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.4",
    "@types/validator": "^13.15.10",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "dependency-cruiser": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^7.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.9",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "pm2": "^6.0.14",
    "tsc-alias": "^1.8.16"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "npm run lint:changed --"
    ]
  }
}
